# Copy to .env (repo root) and fill in real values locally / set as real environment
# variables in production. Never commit .env — it is already in .gitignore.

# --- Runtime ---
NODE_ENV=development
PORT=3000
# Set to "true" only when the server runs behind a reverse proxy (nginx, load balancer, etc.)
TRUST_PROXY=false

# --- Database ---
# Path to the SQLite file. Defaults to server/data/nebi.sqlite if unset.
DB_FILE=

# --- Admin panel (/admin/) ---
# No default credentials exist in code. The server refuses to start in production without these.
ADMIN_USERNAME=
# Generate with: node server/src/lib/hashPassword.js "your-strong-password"
ADMIN_PASSWORD_HASH=
# Any long random string (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_MINUTES=60

# --- NETOPIA Payments ---
# disabled = checkout works, but the pay button explains payment isn't active yet (no HTTP calls made).
# sandbox  = calls NETOPIA's Sandbox environment (test cards only, no real money).
# live     = calls NETOPIA's production environment. Do NOT set this without explicit,
#            separate authorization — this project has not activated real payments.
NETOPIA_ENV=disabled
NETOPIA_API_KEY=
NETOPIA_POS_SIGNATURE=
NETOPIA_PUBLIC_KEY=
NETOPIA_PRIVATE_KEY=
NETOPIA_RETURN_URL=
NETOPIA_NOTIFY_URL=
